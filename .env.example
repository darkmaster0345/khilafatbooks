VITE_SUPABASE_URL=your_supabase_url
# You can use either name; the code will accept both.
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_GA4_SERVICE_ACCOUNT_KEY=your_ga4_service_account_json_base64
VITE_GA4_PROPERTY_ID=your_ga4_property_id
# SECURITY (Finding 3.3): hCaptcha site key for signup bot prevention
# Get yours at https://dashboard.hcaptcha.com/ → Sites → Add New Site
# The test key '10000000-ffff-ffff-ffff-000000000001' is used as fallback in dev
VITE_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
